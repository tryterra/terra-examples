    "@types/figlet": "^1.7.0",
    "@types/node": "^22.15.30",
    "@types/validate-npm-package-name": "^4.0.2",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
