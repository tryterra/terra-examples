{
  "name": "unified-api-web-app",
  "description": "Terra Basecamp: a web app built on Terra's Unified API that connects users' wearables and health data sources to a health dashboard with an AI health assistant. Built with React, Hono on Cloudflare Workers, and Neon Postgres",
  "private": true,
  "version": "0.1.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "setup:reset": "tsx scripts/setup-reset.ts",
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "tsx scripts/deploy.ts",
    "typecheck": "tsc --build",
    "db:auth-schema": "npx @better-auth/cli generate --config better-auth.config.ts --output db/auth-schema.ts --yes",
    "db:generate": "drizzle-kit generate",
    "db:migrate:dev": "drizzle-kit migrate",
    "db:migrate:prod": "tsx scripts/db-migrate-prod.ts",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.74",
    "@cloudflare/ai-chat": "^0.6.2",
    "@cloudflare/codemode": "^0.3.4",
    "@hono/zod-validator": "^0.7.6",
    "@neondatabase/serverless": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.2",
    "@tanstack/store": "^0.9.1",
    "agents": "^0.12.3",
    "ai": "^6.0.175",
    "better-auth": "^1.6.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "fuse.js": "^7.3.0",
    "hono": "^4.12.3",
    "hono-agents": "^3.0.11",
    "motion": "^12.38.0",
    "react": "^19.2.4",
    "react-aria-components": "^1.17.0",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sugar-high": "^1.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss-animate": "^1.0.7",
    "terra-api": "^2.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@clack/prompts": "^1.0.1",
    "@cloudflare/vite-plugin": "^1.35.0",
    "@cloudflare/workers-types": "^4.20260305.0",
    "@react-aria/optimize-locales-plugin": "^1.1.7",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.163.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "drizzle-kit": "^0.31.9",
    "neonctl": "^2.30.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tailwindcss-react-aria-components": "^2.1.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.1.5",
    "wrangler": "^4.87.0"
  }
}
