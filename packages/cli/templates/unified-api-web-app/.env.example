# Run `npm run setup` — it prompts for anything missing, so you never
# need to edit this file by hand. For headless/agent runs (`npm run setup --
# --yes --json`), fill in the credentials below first. See AGENTS.md.

# Cloudflare & Neon use a browser sign-in during setup (`wrangler login`,
# `neonctl auth`). To run headless/CI instead, set these API credentials:
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=   # only needed if the token spans multiple accounts
# NEON_API_KEY=
# NEON_ORG_ID=             # only needed if the account has multiple orgs

# Terra API – dashboard.tryterra.co
TERRA_DEV_ID=
TERRA_API_KEY=
TERRA_WEBHOOK_SECRET=

# Optional – Anthropic. The AI assistant is OFF by default; enable it with
# `npm run setup -- --ai` (needs this key + the Cloudflare Workers Paid plan).
ANTHROPIC_API_KEY=

# Optional – SendGrid (OTP codes log to console if absent)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Auto-managed by setup
APP_NAME=
DATABASE_URL=
NEON_PROJECT_ID=
BETTER_AUTH_SECRET=
