{
  "name": "vantage-web-app",
  "description": "White-label diagnostics storefront and ops console built on Terra's Vantage API - order test kits, track fulfilment, deliver results.",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "dev": "concurrently -n server,client -c blue,green \"tsx watch src/server/node.ts\" \"vite dev\"",
    "build": "vite build",
    "preview": "NODE_ENV=production tsx src/server/node.ts",
    "webhook:tunnel": "tsx scripts/webhook-tunnel.ts",
    "typecheck": "tsc --build",
    "gen:types": "openapi-typescript vendor/vantage-openapi.yaml -o src/server/lib/vantage/types.gen.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src scripts",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "@hono/zod-validator": "^0.7.6",
    "@libsql/client": "^0.15.0",
    "@phosphor-icons/react": "^2.1.10",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.2",
    "@tanstack/store": "^0.9.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.12.3",
    "react": "^19.2.4",
    "react-aria-components": "~1.17.0",
    "react-dom": "^19.2.4",
    "recharts": "^3.8.1",
    "sugar-high": "^1.1.0",
    "tailwind-merge": "^3.3.1",
    "tailwind-variants": "^3.1.1",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@react-aria/optimize-locales-plugin": "^1.1.7",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/router-plugin": "^1.163.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.0",
    "eslint-plugin-import": "^2.32.0",
    "openapi-typescript": "^7.9.1",
    "picocolors": "^1.1.1",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.1",
    "tailwindcss-react-aria-components": "^2.1.0",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^7.3.1",
    "vite-plugin-svgr": "^4.3.0",
    "vitest": "^4.1.5"
  },
  "allowScripts": {
    "esbuild@0.18.20": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "@tailwindcss/oxide@4.3.3": true
  }
}
