# All optional: with no credentials the app runs in DEMO MODE (read-only,
# real captured sandbox fixtures). Add credentials to go live on the sandbox.

# Your Terra credentials (dashboard.tryterra.co → API credentials).
# Vantage access on them is enabled by the Terra team — see the docs:
# https://docs.tryterra.co/vantage-api-docs/account-setup-and-api-keys
TERRA_DEV_ID=
TERRA_API_KEY=

# Signing secret for webhook verification (same dashboard page).
# Needed once you run `npm run webhook:tunnel`.
TERRA_SIGNING_SECRET=

# Optional overrides
# VANTAGE_BASE_URL=https://vantage-sandbox.tryterra.co/api/v1
# DATABASE_URL=file:./data/app.db
# PORT=8787

# Optional: address autocomplete provider. When set, the order form's address
# suggestions use Google Places API (New) — the production-grade choice with
# rooftop-accurate delivery addresses (create a key at
# https://console.cloud.google.com/apis/credentials with Places API enabled).
# When absent, the app falls back to Photon (photon.komoot.io) — free and
# keyless, but fair-use rate limits, no SLA, and street-level OSM data.
# Production checkouts should use the Google key.
GOOGLE_PLACES_API_KEY=

