{
  "name": "terra-pulse",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Terra Pulse: a React web app built on Terra's Streaming API that connects as a consumer and renders live wearable data on a real-time dashboard. Built with React, Vite, Recharts, and a tiny Express token server",
  "license": "Apache-2.0",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "vite",
    "build": "tsc --build && vite build",
    "typecheck": "tsc --build"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "recharts": "^2.15.4"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.11",
    "@types/express": "^4.17.21",
    "@types/node": "^24.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.11",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0"
  }
}
